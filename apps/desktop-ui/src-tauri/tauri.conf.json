{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RADsuite",
  "version": "0.1.0",
  "identifier": "nz.radsuite.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RADsuite",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "macOS": {
      "minimumSystemVersion": "14.0"
    },
    "windows": {
      "digestAlgorithm": "sha256"
    }
  }
}
